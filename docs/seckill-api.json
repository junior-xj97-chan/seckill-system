        "description": "查询某商品在 Redis 中的剩余库存",
        "operationId": "getRedisStock",
        "security": [],
        "parameters": [
          {
            "name": "goodsId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "description": "商品ID",
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
