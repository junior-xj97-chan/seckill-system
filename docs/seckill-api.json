{
  "openapi": "3.0.3",
  "info": {
    "title": "Seckill System API",
    "description": "高并发秒杀系统接口文档\n\n技术栈：Spring Boot 3.x + MySQL + Redis + RabbitMQ + JWT\n\n核心特性：\n- Redis Lua 原子预扣库存（防超卖）\n- RabbitMQ 异步下单（削峰）\n- 数据库乐观锁兜底\n- 接口限流（Redis + AOP）\n- MD5 秒杀地址 + SETNX 去重（防刷）\n- 定时超时关单（释放库存）",
    "version": "1.0.0",
    "contact": {
      "name": "Junior"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "用户模块",
      "description": "用户注册、登录、信息查询"
    },
    {
      "name": "商品模块",
      "description": "秒杀商品列表与详情（无需登录）"
    },
    {
      "name": "秒杀模块",
      "description": "秒杀核心流程：获取地址 → 执行秒杀 → 查询结果（需要登录）"
    },
    {
      "name": "订单模块",
      "description": "订单支付、取消、查询（需要登录）"
    },
    {
      "name": "压测工具",
      "description": "仅限开发/测试环境使用，生产环境必须禁用"
    }
  ],
  "paths": {
    "/api/user/register": {
      "post": {
        "tags": ["用户模块"],
        "summary": "用户注册",
        "description": "注册新用户，手机号不可重复",
        "operationId": "register",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDTO"
              },
              "example": {
                "nickname": "测试用户",
                "phone": "13800138000",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultVoid" },
                "example": {
                  "code": 200,
                  "message": "注册成功",
                  "data": null
                }
              }
            }
          },
          "500": {
            "description": "注册失败",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultVoid" },
                "example": {
                  "code": 500,
                  "message": "该手机号已注册",
                  "data": null
                }
              }
            }
          }
        }
      }
    },
    "/api/user/login": {
      "post": {
        "tags": ["用户模块"],
        "summary": "用户登录",
        "description": "手机号 + 密码登录，返回 JWT Token",
        "operationId": "login",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDTO"
              },
              "example": {
                "phone": "13800000001",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultLoginData" },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": {
                    "token": "eyJhbGciOiJIUzUxMiJ9...",
                    "userId": 1,
                    "nickname": "测试用户A"
                  }
                }
              }
            }
          },
          "500": {
            "description": "登录失败",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultVoid" },
                "example": {
                  "code": 500,
                  "message": "用户不存在 / 密码错误",
                  "data": null
                }
              }
            }
          }
        }
      }
    },
    "/api/user/info": {
      "get": {
        "tags": ["用户模块"],
        "summary": "获取当前用户信息",
        "description": "需要登录，通过 JWT Token 识别用户",
        "operationId": "getUserInfo",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultUser" },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": {
                    "id": 1,
                    "nickname": "测试用户A",
                    "phone": "13800000001",
                    "avatar": null,
                    "createTime": "2026-04-17T10:33:31"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/goods/list": {
      "get": {
        "tags": ["商品模块"],
        "summary": "秒杀商品列表",
        "description": "获取所有进行中的秒杀商品（仅展示有库存的）",
        "operationId": "listGoods",
        "security": [],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultGoodsList" },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": [
                    {
                      "id": 1,
                      "goodsName": "iPhone 17 Pro",
                      "goodsTitle": "iPhone 17 Pro 限量秒杀",
                      "goodsImg": "https://example.com/iphone17.jpg",
                      "price": 9999.00,
                      "seckillPrice": 6999.00,
                      "stockCount": 1000,
                      "seckillStock": 100,
                      "startDate": "2026-04-01T00:00:00",
                      "endDate": "2026-12-31T23:59:59"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/goods/detail/{goodsId}": {
      "get": {
        "tags": ["商品模块"],
        "summary": "商品详情",
        "description": "获取指定秒杀商品的详细信息",
        "operationId": "getGoodsDetail",
        "security": [],
        "parameters": [
          {
            "name": "goodsId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "description": "商品ID",
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultGoods" },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": {
                    "id": 1,
                    "goodsName": "iPhone 17 Pro",
                    "goodsTitle": "iPhone 17 Pro 限量秒杀",
                    "goodsImg": "https://example.com/iphone17.jpg",
                    "goodsDetail": "iPhone 17 Pro 详细介绍...",
                    "price": 9999.00,
                    "costPrice": 6000.00,
                    "stockCount": 1000,
                    "seckillPrice": 6999.00,
                    "seckillStock": 100,
                    "startDate": "2026-04-01T00:00:00",
                    "endDate": "2026-12-31T23:59:59",
                    "createTime": "2026-04-17T10:33:31"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/seckill/path/{goodsId}": {
      "get": {
        "tags": ["秒杀模块"],
        "summary": "获取秒杀地址",
        "description": "获取商品的 MD5 加密秒杀地址，防止直接暴露秒杀接口。地址有效期 5 分钟。",
        "operationId": "getSeckillPath",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "goodsId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "description": "商品ID",
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultString" },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": "dca9653cf28baa1f3cb6e90b6b272271"
                }
              }
            }
          },
          "500": {
            "description": "失败",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultString" },
                "examples": {
                  "not_started": {
                    "summary": "秒杀未开始",
                    "value": { "code": 500, "message": "秒杀尚未开始", "data": null }
                  },
                  "ended": {
                    "summary": "秒杀已结束",
                    "value": { "code": 500, "message": "秒杀已结束", "data": null }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/seckill/execute/{goodsId}": {
      "post": {
        "tags": ["秒杀模块"],
        "summary": "执行秒杀",
        "description": "核心秒杀接口。流程：验证地址 → Redis去重 → Lua原子预扣库存 → MQ异步下单。\n\n限流规则：每秒最多 100 次请求。\n同一用户同一商品只能秒杀一次。",
        "operationId": "executeSeckill",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "goodsId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "description": "商品ID",
            "example": 1
          },
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "通过 /api/seckill/path/{goodsId} 获取的秒杀地址",
            "example": "dca9653cf28baa1f3cb6e90b6b272271"
          }
        ],
        "responses": {
          "200": {
            "description": "秒杀成功（排队中）",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultString" },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": "排队中，请稍后查询秒杀结果"
                }
              }
            }
          },
          "500": {
            "description": "秒杀失败",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultString" },
                "examples": {
                  "invalid_path": {
                    "summary": "秒杀地址无效",
                    "value": { "code": 500, "message": "秒杀地址无效，请重新获取", "data": null }
                  },
                  "sold_out": {
                    "summary": "商品已售罄",
                    "value": { "code": 500, "message": "商品已售罄", "data": null }
                  },
                  "duplicate": {
                    "summary": "重复秒杀",
                    "value": { "code": 500, "message": "您已参与过该商品的秒杀，请勿重复操作", "data": null }
                  },
                  "rate_limited": {
                    "summary": "接口限流",
                    "value": { "code": 500, "message": "请求过于频繁，请稍后再试", "data": null }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/seckill/result/{goodsId}": {
      "get": {
        "tags": ["秒杀模块"],
        "summary": "查询秒杀结果",
        "description": "轮询查询秒杀结果。返回值：\n- \"排队中\" → 仍在 MQ 处理中\n- \"SUCCESS:订单号\" → 秒杀成功\n- \"FAILED:订单超时关闭\" → 订单超时被关闭",
        "operationId": "getSeckillResult",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "goodsId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "description": "商品ID",
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultString" },
                "examples": {
                  "pending": {
                    "summary": "排队中",
                    "value": { "code": 200, "message": "success", "data": "排队中" }
                  },
                  "success": {
                    "summary": "秒杀成功",
                    "value": { "code": 200, "message": "success", "data": "SUCCESS:17763939689054650" }
                  },
                  "failed": {
                    "summary": "订单超时",
                    "value": { "code": 200, "message": "success", "data": "FAILED:订单超时关闭" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/order/list": {
      "get": {
        "tags": ["订单模块"],
        "summary": "我的订单列表",
        "description": "查询当前登录用户的所有订单",
