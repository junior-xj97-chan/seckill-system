          "price": { "type": "number", "format": "double", "description": "原价", "example": 9999.00 },
          "costPrice": { "type": "number", "format": "double", "description": "成本价", "example": 6000.00 },
          "stockCount": { "type": "integer", "description": "总库存", "example": 1000 },
          "seckillPrice": { "type": "number", "format": "double", "description": "秒杀价", "example": 6999.00 },
          "seckillStock": { "type": "integer", "description": "秒杀剩余库存", "example": 100 },
          "startDate": { "type": "string", "format": "date-time", "description": "秒杀开始时间", "example": "2026-04-01T00:00:00" },
          "endDate": { "type": "string", "format": "date-time", "description": "秒杀结束时间", "example": "2026-12-31T23:59:59" },
          "createTime": { "type": "string", "format": "date-time", "description": "创建时间" },
          "updateTime": { "type": "string", "format": "date-time", "description": "更新时间" }
        }
      },
      "SeckillOrder": {
        "type": "object",
