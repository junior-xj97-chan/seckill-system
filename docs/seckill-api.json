        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResultOrder" },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": {
                    "id": 1,
                    "userId": 1,
                    "goodsId": 1,
